/* PROC DATASETS */
*
THE PROC DATASETS STATMENT IN SAS USED TO MANIPULATE SAS DATASETS.
TO PERFORM A VARITY OF OPERATAION ON DATSETS.
SUNCH AS COPYING ,RENAMING, DELETING, AND MODEFYING DATASETS.;

DATA NEWCLASS;
SET SASHELP.CLASS;
RUN;

DATA NEWCARS;
SET SASHELP.CLASS;
RUN;

DATA NEWSHOES;
SET SASHELP.CLASS;
RUN;

DATA NEWAIR;
SET SASHELP.CLASS;
RUN;


/* DISPLAY A LIST OF ALL DATASETS IN A LIBRARY */

PROC DATASETS LIBRARY=WORK;
RUN;
QUIT;

PROC DATASETS LIBRARY=WORK MEMTYPE=DATA;
RUN;
QUIT;

PROC DATASETS LIB=WORK MEMTYPE=DATA;
CONTENTS DATA=NEWCARS;
RUN;
QUIT;

LIBNAME PG1 "/home/u64168920/EPG2V2";

/* HOW TO COPY SOME DATASETS FROM A LIBRARY */

PROC DATASETS LIB=WORK MEMTYPE=DATA;
COPY IN=WORK OUT=PG1;
RUN;
QUIT;

PROC DATASETS LIB=WORK MEMTYPE=DATA;
COPY IN=WORK OUT=PG1;
SELECT NEWCLASS NEWAIR;
RUN;
QUIT;


/* HOW TO MOVE DATASETS FROM A LIBRARY AND PASTE INTO ANOTHER LIBRARY */

PROC DATASETS;
COPY IN =WORK OUT=PG1 MOVE;
SELECT NEWSHOES;
RUN;
QUIT;

PROC DATASETS LIB=PG1 KILL;
RUN;
QUIT;


/* TO RENAME SAS DATASET */

PROC DATASETS LIB=WORK MEMTYPE=DATA;
CHANGE NEWCARS = CARS;
CHANGE NEWCLASS = CLASS;
RUN;
QUIT;

/* MODEFYING DATSET AND VARIABLE ATRIBUTION */

DATA WORK.CLASS3;
SET SASHELP.CLASS;
RUN;

PROC DATASETS LIBRARY=WORK ;
MODIFY CLASS3 (LABEL=STUDENT_CLASS);
FORMAT HEIGHT WEIGHT BEST.;
LABEL NAME="STUDENT NAME"
SEX="GENDER"
HEIGHT="LENGTH"
WEIGHT="MASS"
AGE="GROWTH";
RUN;
CONTENTS DATA=CLASS3;
RUN;
QUIT;
